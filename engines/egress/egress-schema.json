{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xi-io.local/screen_scraper/engines/egress/egress-schema.json",
  "title": "screen_scraper Framework-Aligned Egress Action Schema",
  "type": "object",
  "required": [
    "egress_id",
    "product_id",
    "project_id",
    "action_type",
    "created_at",
    "approval_state",
    "target_type",
    "target_id",
    "safety"
  ],
  "properties": {
    "egress_id": { "type": "string", "format": "uuid" },
    "export_id": { "type": ["string", "null"], "format": "uuid" },
    "product_id": { "type": "string", "const": "screen_scraper" },
    "project_id": { "type": "string" },
    "document_id": { "type": ["string", "null"] },
    "correlation_id": { "type": ["string", "null"] },
    "causation_event_id": { "type": ["string", "null"] },
    "adapter_version": { "type": "string" },
    "canonical_package_type": {
      "type": "string",
      "enum": [
        "DocumentEgressPackage",
        "ReportEgressPackage",
        "DataEgressPackage",
        "MediaEgressPackage",
        "ReleaseEgressPackage",
        "ArchiveEgressPackage"
      ],
      "default": "DocumentEgressPackage"
    },
    "action_type": {
      "type": "string",
      "enum": [
        "ui_update",
        "document_patch",
        "document_generate",
        "document_export",
        "report_export",
        "data_export",
        "source_library_update",
        "metadata_update",
        "rights_update",
        "media_asset_update",
        "snapshot_create",
        "rollback_restore",
        "provider_call",
        "repo_action",
        "release_package",
        "notification",
        "external_tool_call"
      ]
    },
    "document_type": {
      "type": ["string", "null"],
      "enum": [
        null,
        "article",
        "book",
        "chapter",
        "manual",
        "guide",
        "report",
        "brief",
        "research_packet",
        "legal_packet",
        "technical_spec",
        "runbook",
        "release_notes",
        "field_guide",
        "story_bible",
        "character_sheet",
        "location_sheet",
        "lore_entry",
        "media_pack_manifest",
        "pool_report",
        "scoreboard_report",
        "metadata_report",
        "lexicon_report",
        "source_package",
        "archive_package"
      ],
      "default": "article"
    },
    "format": {
      "type": ["string", "null"],
      "enum": [
        null,
        "md",
        "html",
        "txt",
        "json",
        "zip",
        "docx",
        "pdf",
        "epub",
        "odt",
        "rtf",
        "tex",
        "fountain",
        "csv",
        "yaml"
      ]
    },
    "profile": {
      "type": ["string", "null"],
      "enum": [
        null,
        "Draft Review",
        "Clean Artifact",
        "Submission Artifact",
        "Web Preview",
        "Ebook Draft",
        "Source Package",
        "Archive Package",
        "Metadata Report",
        "Lexicon Report",
        "Operations Package",
        "Release Package"
      ]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "actor_type": {
      "type": "string",
      "enum": ["user", "system", "ai", "job", "provider"],
      "default": "user"
    },
    "target_type": { "type": "string" },
    "target_id": { "type": "string" },
    "approval_state": {
      "type": "string",
      "enum": [
        "not_required",
        "required",
        "previewed",
        "approved",
        "rejected",
        "blocked",
        "failed",
        "completed"
      ]
    },
    "preview_ref": {
      "type": ["object", "null"],
      "properties": {
        "summary": { "type": "string" },
        "diff_ref": { "type": ["string", "null"] },
        "vault_artifact_id": { "type": ["string", "null"] },
        "warning_count": { "type": ["integer", "null"], "minimum": 0 }
      },
      "additionalProperties": false
    },
    "output_ref": {
      "type": ["object", "null"],
      "properties": {
        "storage_mode": {
          "type": "string",
          "enum": [
            "ui_only",
            "vault_ref",
            "file_path",
            "repo_path",
            "external_ref",
            "local_download",
            "local_project_exports_directory",
            "product_runtime_storage",
            "local_preview_only",
            "none"
          ]
        },
        "path": { "type": ["string", "null"] },
        "vault_artifact_id": { "type": ["string", "null"] },
        "artifact_id": { "type": ["string", "null"] },
        "hash": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "manifest": {
      "type": ["object", "null"],
      "properties": {
        "manifest_version": { "type": "integer", "minimum": 1 },
        "artifact_count": { "type": "integer", "minimum": 0 },
        "source_reference_count": { "type": "integer", "minimum": 0 },
        "lexicon_term_count": { "type": "integer", "minimum": 0 },
        "media_item_count": { "type": "integer", "minimum": 0 },
        "warning_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "events_emitted": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "safety": {
      "type": "object",
      "required": [
        "repo_safe",
        "cloud_safe",
        "requires_user_approval",
        "destructive",
        "raw_payload_safe"
      ],
      "properties": {
        "repo_safe": { "type": "boolean" },
        "cloud_safe": { "type": "boolean" },
        "requires_user_approval": { "type": "boolean" },
        "destructive": { "type": "boolean" },
        "raw_payload_safe": { "type": "boolean" },
        "redaction_required": { "type": "boolean" },
        "blocked_reason": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
